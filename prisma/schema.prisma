generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

/**
 * =========================
 * Enums (Only Safe Ones)
 * =========================
 */
enum AdminRole {
  ROOT
  FULL
  SCOPED
}

enum BayKind {
  SINGLE // one golfer, handedness-specific
  GROUP  // multi-golfer, either handedness
}

enum Handedness {
  RH
  LH
}

/**
 * =========================
 * Models
 * =========================
 */
model Location {
  id                               String   @id @default(uuid())
  name                             String
  slug                             String   @unique
  disabled                         Boolean  @default(false)
  bookingNote                      String?
  passAccessUrl                    String?

  open24Hours                      Boolean  @default(false)
  hours                            Json     // init to [] in app if null
  minBookingMinutes                Int      @default(60)
  maxBookingMinutes                Int      @default(120)
  maxActiveBookingsPerGuest        Int      @default(2)
  activeBookingIdentifyBy          String   @default("either")
  activeBookingWindowHours         Int      @default(24)
  maxConsecutiveBookingsPerGuest   Int      @default(2)

  bays                             Bay[]
  bookings                         Booking[]
  adminLinks                       AdminLocation[]
  notifications                    Notification[]

  createdAt                        DateTime @default(now())
  updatedAt                        DateTime @updatedAt
}

model Bay {
  id          String   @id @default(uuid())
  number      Int
  name        String?
  locationId  String
  location    Location @relation(fields: [locationId], references: [id])

  kind        BayKind     @default(GROUP)
  handedness  Handedness? // only set when kind = SINGLE
  capacity    Int         @default(4)

  @@unique([locationId, number])
  @@index([locationId])
}

model Booking {
  id              String    @id @default(uuid())
  locationId      String
  bayNumber       Int
  start           DateTime
  end             DateTime
  firstName       String
  lastName        String
  phone           String
  email           String
  managementToken String    @unique @default(uuid())
  canceledAt      DateTime?

  createdAt       DateTime  @default(now())
  Location        Location  @relation(fields: [locationId], references: [id])

  @@index([locationId, bayNumber, start])
  @@index([locationId, start, end])
  @@index([email, start])
}

// --- Admins & Access Control ---
model Admin {
  id        String   @id @default(cuid())
  phone     String   @unique
  name      String?
  role      AdminRole @default(SCOPED)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  locations AdminLocation[]
}

model AdminLocation {
  id         String   @id @default(cuid())
  adminId    String
  locationId String
  createdAt  DateTime @default(now())

  admin     Admin    @relation(fields: [adminId], references: [id], onDelete: Cascade)
  location  Location @relation(fields: [locationId], references: [id], onDelete: Cascade)

  @@unique([adminId, locationId])
}

/**
 * =========================
 * Notifications — kind & channel are TEXT in DB
 * =========================
 */
model Notification {
  id          String   @id @default(cuid())
  locationId  String
  location    Location @relation(fields: [locationId], references: [id], onDelete: Cascade)
  kind        String   @default("NOTIFICATION")  // TEXT + CHECK('CONFIRMATION', 'NOTIFICATION')
  channel     String   @default("EMAIL")        // TEXT + CHECK('EMAIL', 'TEXT')
  hoursBefore Int      @default(0)
  template    String
  enabled     Boolean  @default(true)
  order       Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([locationId, kind, channel, hoursBefore])
  @@index([locationId, kind, channel])
}

model NotificationLog {
  id             String   @id @default(cuid())
  bookingId      String
  notificationId String
  channel        String   // TEXT + CHECK('EMAIL', 'TEXT')
  status         String   // "SENT" | "FAILED"
  providerId     String?
  error          String?
  sentAt         DateTime @default(now())

  @@index([bookingId])
  @@index([notificationId])
  @@index([bookingId, notificationId, channel])
}

/**
 * =========================
 * One time passcode
 * =========================
 */
model Otp {
  id        String   @id @default(cuid())
  phone     String   @unique
  code      String
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([phone])
}